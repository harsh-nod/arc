arc.module @interp_if_else_false {
  arc.func @main() -> i64 {
  ^entry:
    %zero = arc.const 0 : i64
    %r = arc.if %zero {
    ^then:
      %a = arc.const 10 : i64
      arc.yield %a
    } else {
    ^else_body:
      %b = arc.const 20 : i64
      arc.yield %b
    }
    arc.return %r : i64
  }
}
